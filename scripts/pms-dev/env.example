# PMS Dev Runner — template
#
# This is a reference template. The runner reads env from:
# - <root>/tenant_portal_backend/.env
# - <root>/tenant_portal_app/.env
#
# Required:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?schema=public"
#
# Recommended:
# JWT_SECRET="dev-secret-change-me"
#
# Frontend:
# VITE_API_URL=http://localhost:3001/api
