# Notion
NOTION_API_KEY=
NOTION_EXECUTION_REQUESTS_DB_ID=
NOTION_EXECUTION_PERMITS_DB_ID=
NOTION_PROJECTS_DB_ID=

# Redis
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5
LOCK_TTL_MS=900000

# Webhook auth
WEBHOOK_SECRET=
PORT=3000

# Notion API version for schema verification (default: 2022-06-28)
NOTION_SCHEMA_VERSION=2022-06-28

# Optional: override Notion property names (JSON object)
# Example: {"permitStatus":"Status","permitApprovedMode":"Approved Mode"}
NOTION_PROP_OVERRIDES_JSON=

# Optional (recommended): poller cadence when run as a service
POLL_INTERVAL_MS=2000

# Script runner hardening: comma-separated allowlisted prefixes.
# Default: <repo>/scripts/
SCRIPT_ALLOWLIST_PREFIXES=/home/jordanh316/clawd/scripts/

# GitHub App (required only if you execute GitHub-targeted non-dry-run jobs)
GITHUB_APP_ID=
# Either inline PEM or a path to a PEM file
GITHUB_APP_PRIVATE_KEY_PEM=
GITHUB_APP_PRIVATE_KEY_PATH=
# Optional: if set, skips repo installation lookup
GITHUB_APP_INSTALLATION_ID=

# GitHub enforcement defaults
# Scripts should use Request.Target Scope ID (owner/repo) + Request.Target Branch.
# Permit.Allowed Actions should include: read (for dry-run) and push (for non-dry-run)
