{
    "core_definition": {
        "unit_health": "cash_flow_stability",
        "core_net_receipts": "settled rent payments applied to rent ledger",
        "non_core_cash_events": [
            "late_fees",
            "credits",
            "concessions",
            "refunds",
            "chargebacks"
        ]
    },
    "forecast_model": {
        "structure": "hierarchical_shrinkage",
        "levels": [
            "unit",
            "property",
            "portfolio"
        ],
        "weights": [
            "w_u",
            "w_p",
            "w_g"
        ]
    },
    "stability_score": {
        "formula": "100 - \u03b1*CV(revenue) - \u03b2*P(disruption) - \u03b3*ExpenseVolatility - guardrail_penalties"
    },
    "guardrails": [
        "rent_late_threshold",
        "vacancy_status",
        "work_order_backlog",
        "eviction_flag"
    ],
    "federated_learning": {
        "local_node": [
            "store_raw_data",
            "compute_forecasts",
            "send_parameter_updates"
        ],
        "central_coordinator": [
            "aggregate_updates",
            "update_global_priors",
            "redistribute_models"
        ]
    }
}